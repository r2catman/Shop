<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shop</title>
  <link rel="dns-prefetch" href="https://fonts.googleapis.com">
  <link rel="dns-prefetch" href="https://fonts.gstatic.com">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0f;
      --bg2: #111118;
      --bg3: #16161f;
      --border: rgba(255,255,255,0.07);
      --border2: rgba(255,255,255,0.12);
      --text: #f0f0f5;
      --muted: #6b6b80;
      --accent: #7c6af5;
      --accent2: #9b8dff;
      --accent-bg: rgba(124,106,245,0.1);
      --accent-border: rgba(124,106,245,0.3);
      --btc: #f7931a;
      --eth: #627eea;
      --ltc: #bfbbbb;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.6;
    }

    /* NAV */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,15,0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      height: 58px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--accent2);
      text-transform: uppercase;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      color: var(--muted);
      transition: color 0.15s;
    }

    .nav-links a:hover { color: var(--text); }
    .nav-links a.active { color: var(--accent2); }

    /* HERO */
    .hero {
      text-align: center;
      padding: 5rem 1.5rem 3rem;
      max-width: 600px;
      margin: 0 auto;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--accent-bg);
      border: 1px solid var(--accent-border);
      border-radius: 20px;
      padding: 4px 14px;
      font-size: 11px;
      font-weight: 600;
      color: var(--accent2);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }

    .hero h1 {
      font-size: 42px;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-bottom: 1rem;
    }

    .hero h1 span { color: var(--accent2); }

    .hero p {
      font-size: 15px;
      color: var(--muted);
      max-width: 400px;
      margin: 0 auto;
    }

    /* MAIN LAYOUT */
    main {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 1.5rem 5rem;
    }

    /* SECTION CARDS */
    .card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.75rem;
      margin-bottom: 1.25rem;
      transition: border-color 0.2s;
    }

    .card:hover { border-color: var(--border2); }

    .card-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 1.25rem;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .card-title-group {}

    .card-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent2);
      margin-bottom: 4px;
    }

    .card-title {
      font-size: 20px;
      font-weight: 700;
      color: var(--text);
    }

    .card-desc {
      font-size: 13px;
      color: var(--muted);
      margin-top: 3px;
    }

    /* PRICE DISPLAY */
    .price-group {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 6px;
    }

    .price-tag {
      font-size: 22px;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -0.02em;
    }

    .crypto-row {
      display: flex;
      gap: 6px;
    }

    .cpill {
      font-size: 10px;
      font-weight: 700;
      padding: 3px 9px;
      border-radius: 20px;
      letter-spacing: 0.05em;
    }

    .cpill.btc { background: rgba(247,147,26,0.12); color: var(--btc); border: 1px solid rgba(247,147,26,0.25); }
    .cpill.eth { background: rgba(98,126,234,0.12); color: var(--eth); border: 1px solid rgba(98,126,234,0.25); }
    .cpill.ltc { background: rgba(191,187,187,0.1); color: var(--ltc); border: 1px solid rgba(191,187,187,0.2); }

    /* TABS */
    .tabs-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 1.25rem;
    }

    .tab-btn {
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 500;
      padding: 5px 14px;
      border-radius: 20px;
      border: 1px solid var(--border2);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s;
    }

    .tab-btn:hover {
      border-color: var(--accent-border);
      color: var(--text);
    }

    .tab-btn.active {
      background: var(--accent-bg);
      border-color: var(--accent-border);
      color: var(--accent2);
    }

    /* LOG PANEL */
    .log-panel {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .log-name {
      font-size: 16px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 3px;
    }

    .log-sub {
      font-size: 12px;
      color: var(--muted);
    }

    .log-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 6px;
    }

    .log-price {
      font-size: 20px;
      font-weight: 800;
      color: var(--text);
    }

    /* DIVIDER */
    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 1.5rem 0;
    }

    /* WALLETS */
    .wallet-list { display: flex; flex-direction: column; gap: 10px; }

    .wallet-item {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      transition: border-color 0.15s;
    }

    .wallet-item:hover { border-color: var(--border2); }

    .wallet-coin {
      font-size: 11px;
      font-weight: 700;
      min-width: 36px;
      letter-spacing: 0.05em;
    }

    .wallet-coin.btc { color: var(--btc); }
    .wallet-coin.eth { color: var(--eth); }
    .wallet-coin.ltc { color: var(--ltc); }

    .wallet-addr {
      font-family: 'Courier New', monospace;
      font-size: 12px;
      color: var(--muted);
      word-break: break-all;
      flex: 1;
    }

    .copy-btn {
      font-family: 'Inter', sans-serif;
      font-size: 11px;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 6px;
      border: 1px solid var(--border2);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s;
      white-space: nowrap;
    }

    .copy-btn:hover { color: var(--text); border-color: var(--accent-border); }
    .copy-btn.copied { color: #4ade80; border-color: rgba(74,222,128,0.3); }

    /* STEPS */
    .steps { display: flex; flex-direction: column; gap: 12px; margin-top: 1rem; }

    .step {
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }

    .step-num {
      min-width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--accent-bg);
      border: 1px solid var(--accent-border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      color: var(--accent2);
      margin-top: 1px;
    }

    .step-text {
      font-size: 14px;
      color: var(--muted);
      padding-top: 4px;
    }

    .step-text a {
      color: var(--accent2);
      text-decoration: none;
    }

    .step-text a:hover { text-decoration: underline; }

    /* FOOTER */
    footer {
      border-top: 1px solid var(--border);
      text-align: center;
      padding: 2rem 1.5rem;
      font-size: 12px;
      color: var(--muted);
    }

    @media (max-width: 600px) {
      .hero h1 { font-size: 28px; }
      .card-header { flex-direction: column; }
      .price-group { align-items: flex-start; }
      nav { padding: 0 1rem; }
      .nav-links { gap: 1rem; }
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-logo">Shop</div>
  <ul class="nav-links">
    <li><a href="#cards">Cards</a></li>
    <li><a href="#logs">Logs</a></li>
    <li><a href="#accounts">Accounts</a></li>
    <li><a href="#purchase">Purchase</a></li>
  </ul>
</nav>

<div class="hero">
  <div class="hero-badge">&#9679; Crypto Only</div>
  <h1>The <span>Shop</span></h1>
  <p>Cards, logs & accounts. Pay with BTC, ETH, or LTC and receive your items fast.</p>
</div>

<main>

  <!-- CARDS -->
  <div class="card" id="cards">
    <div class="card-header">
      <div class="card-title-group">
        <div class="card-label">Section 01</div>
        <div class="card-title">Cards</div>
        <div class="card-desc">Gift card logs for various brands</div>
      </div>
      <div class="price-group">
        <div class="price-tag">$15</div>
        <div class="crypto-row">
          <span class="cpill btc">BTC</span>
          <span class="cpill eth">ETH</span>
          <span class="cpill ltc">LTC</span>
        </div>
      </div>
    </div>
  </div>

  <!-- LOGS -->
  <div class="card" id="logs">
    <div class="card-header">
      <div class="card-title-group">
        <div class="card-label">Section 02</div>
        <div class="card-title">Logs</div>
        <div class="card-desc">Select a store to see pricing</div>
      </div>
    </div>

    <div class="tabs-wrap" id="tabsWrap"></div>

    <div class="log-panel" id="logPanel">
      <div>
        <div class="log-name" id="logName">Subway</div>
        <div class="log-sub" id="logSub">Various balances available</div>
      </div>
      <div class="log-right">
        <div class="log-price" id="logPrice">$5 – $15</div>
        <div class="crypto-row">
          <span class="cpill btc">BTC</span>
          <span class="cpill eth">ETH</span>
          <span class="cpill ltc">LTC</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ACCOUNTS -->
  <div class="card" id="accounts">
    <div class="card-header">
      <div class="card-title-group">
        <div class="card-label">Section 03</div>
        <div class="card-title">Accounts</div>
        <div class="card-desc">Priced per line</div>
      </div>
      <div class="price-group">
        <div class="price-tag">$5 / line</div>
        <div class="crypto-row">
          <span class="cpill btc">BTC</span>
          <span class="cpill eth">ETH</span>
          <span class="cpill ltc">LTC</span>
        </div>
      </div>
    </div>
  </div>

  <!-- PURCHASE -->
  <div class="card" id="purchase">
    <div class="card-header">
      <div class="card-title-group">
        <div class="card-label">Section 04</div>
        <div class="card-title">How to Purchase</div>
        <div class="card-desc">Send crypto to one of the addresses below</div>
      </div>
    </div>

    <div class="wallet-list">
      <div class="wallet-item">
        <span class="wallet-coin btc">BTC</span>
        <span class="wallet-addr">bc1qzr7drps88flc2dtpld6u3hlwrpx9r6fgmhaakq</span>
        <button class="copy-btn" onclick="copyAddr(this,'bc1qzr7drps88flc2dtpld6u3hlwrpx9r6fgmhaakq')">Copy</button>
      </div>
      <div class="wallet-item">
        <span class="wallet-coin eth">ETH</span>
        <span class="wallet-addr">0x9881394f10046FDb43666323d6DD4Da61AF5B9AD</span>
        <button class="copy-btn" onclick="copyAddr(this,'0x9881394f10046FDb43666323d6DD4Da61AF5B9AD')">Copy</button>
      </div>
      <div class="wallet-item">
        <span class="wallet-coin ltc">LTC</span>
        <span class="wallet-addr">ltc1qgcslper3uegjcs4uqga4w0hu6cn2lcaxhwzc04</span>
        <button class="copy-btn" onclick="copyAddr(this,'ltc1qgcslper3uegjcs4uqga4w0hu6cn2lcaxhwzc04')">Copy</button>
      </div>
    </div>

    <hr>

    <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-text">Send the exact amount in your chosen crypto to the wallet address above</div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-text">Email your proof of payment to <a href="mailto:1nonlyN23@proton.me">1nonlyN23@proton.me</a></div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-text">Join the Discord — <a href="https://discord.gg/PtUnfhr9Ua" target="_blank">discord.gg/PtUnfhr9Ua</a> — open a ticket and send proof of payment there too, if item is OOS ( out of stock ) i will let you know and give you a log of choice or refund.</div>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <div class="step-text">Sit back and wait for your items to be delivered!</div>
      </div>
    </div>
  </div>

</main>

<footer>
  All sales are final &nbsp;&middot;&nbsp; Crypto payments only
</footer>

<script>
  const logs = [
    { key: 'subway',        name: 'Subway',                       price: '$5 – $15' },
    { key: 'bathbody',      name: 'Bath & Body Works',            price: '$5 – $15' },
    { key: 'amc',           name: 'AMC Theatres',                 price: '$5 – $15' },
    { key: 'yelp',          name: 'Yelp',                         price: '$5 – $15' },
    { key: 'ulta',          name: 'Ulta Beauty',                  price: '$5 – $15' },
    { key: 'onlyfans',      name: 'OnlyFans',                     price: '$5 – $15' },
    { key: 'ihg',           name: 'IHG Hotels',                   price: '$5 – $15' },
    { key: 'discover',      name: 'Discover',                     price: '$5 – $15' },
    { key: 'cinemark',      name: 'Cinemark',                     price: '$5 – $15' },
    { key: 'marriott',      name: 'Marriott Bonvoy',              price: '$5 – $15' },
    { key: 'moes',          name: "Moe's Southwest Grill",        price: '$5 – $15' },
    { key: 'fandango',      name: 'Fandango',                     price: '$5 – $15' },
    { key: 'neimanmarcus',  name: 'Neiman Marcus',                price: '$5 – $15' },
    { key: 'macys',         name: "Macy's",                       price: '$5 – $15' },
    { key: 'smoothieking',  name: 'Smoothie King',                price: '$5 – $15' },
    { key: 'hilton',        name: 'Hilton Hotels & Resorts',      price: '$5 – $15' },
    { key: 'coffeebean',    name: 'Coffee Bean & Tea Leaf',       price: '$5 – $15' },
    { key: 'jcpenney',      name: 'JCPenney',                     price: '$5 – $15' },
    { key: 'texasroadhouse',name: 'Texas Roadhouse',              price: '$5 – $15' },
    { key: 'bloomingdales', name: "Bloomingdale's",               price: '$5 – $15' },
    { key: 'gap',           name: 'GAP',                          price: '$5 – $15' },
    { key: 'petsmart',      name: 'PetSmart',                     price: '$5 – $15' },
    { key: 'aeropostale',   name: 'Aeropostale',                  price: '$5 – $15' },
    { key: 'frontier',      name: 'Frontier Airlines',            price: '$5 – $15' },
    { key: 'roku',          name: 'Roku',                         price: '$5 – $15' },
    { key: 'chewy',         name: 'Chewy',                        price: '$5 – $15' },
    { key: 'alaska',        name: 'Alaska Airlines',              price: '$150 – $200' },
    { key: 'streaming',     name: 'Streaming (Netflix, HBO, UFC & more)', price: '$5 – $15' },
  ];

  const wrap = document.getElementById('tabsWrap');
  const logName = document.getElementById('logName');
  const logSub = document.getElementById('logSub');
  const logPrice = document.getElementById('logPrice');
  let activeBtn = null;

  logs.forEach((log, i) => {
    const btn = document.createElement('button');
    btn.className = 'tab-btn' + (i === 0 ? ' active' : '');
    btn.textContent = log.name;
    btn.addEventListener('click', () => {
      if (activeBtn) activeBtn.classList.remove('active');
      btn.classList.add('active');
      activeBtn = btn;
      logName.textContent = log.name;
      logSub.textContent = 'Various balances available';
      logPrice.textContent = log.price;
    });
    if (i === 0) activeBtn = btn;
    wrap.appendChild(btn);
  });

  function copyAddr(btn, addr) {
    navigator.clipboard.writeText(addr).then(() => {
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = 'Copy';
        btn.classList.remove('copied');
      }, 2000);
    });
  }
</script>

</body>
</html>
